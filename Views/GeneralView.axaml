<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="screenshareav.Views.GeneralView">
  <StackPanel Margin="32" Spacing="12">
    <TextBlock Text="Mode Selector" FontWeight="Bold" FontSize="18"/>
    <ComboBox x:Name="ModeSelector" Width="200" Margin="0,12,0,0">
      <ComboBoxItem Content="Server"/>
      <ComboBoxItem Content="Client"/>
    </ComboBox>
    <TextBlock Text="Select the mode for this device. This setting is saved." Margin="0,8,0,0"/>

    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
      <TextBlock Text="Access Code:" FontWeight="SemiBold"/>
      <TextBlock x:Name="AccessCodeText" Text="------" FontFamily="Consolas" FontSize="16"/>
      <Button x:Name="CopyCodeBtn" Content="Copy" Width="60"/>
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
      <TextBlock Text="Status:" FontWeight="SemiBold"/>
      <TextBlock x:Name="ConnectionStatusText" Text="Disconnected" Foreground="#B3261E"/>
    </StackPanel>
  </StackPanel>
</UserControl>

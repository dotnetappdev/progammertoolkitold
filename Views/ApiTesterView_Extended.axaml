<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ProgrammersToolKit.Views.ApiTesterView_Extended"
             x:CompileBindings="False">
  <DockPanel Margin="24">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <TextBlock Text="API Tester (Extended)" FontWeight="Bold" FontSize="20"/>
      <Button x:Name="NewApiCallBtn" Content="New" Width="60"/>
      <Button x:Name="SaveApiCallBtn" Content="Save" Width="60"/>
      <Button x:Name="DeleteApiCallBtn" Content="Delete" Width="60"/>
      <Button x:Name="SendApiCallBtn" Content="Send" Width="80" Background="#0078D4" Foreground="White" FontWeight="Bold"/>
    </StackPanel>
    <Grid ColumnDefinitions="2*,3*" RowDefinitions="Auto,Auto,*,2*">
      <!-- Left: API Call Editor -->
      <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="4" Spacing="10">
        <TextBlock Text="Saved Calls" FontWeight="SemiBold"/>
        <ListBox x:Name="SavedApiCallsListBox" Height="120"/>
        <TextBlock Text="Endpoint URL" FontWeight="SemiBold"/>
        <TextBox x:Name="ApiUrlBox"/>
        <TextBlock Text="HTTP Method" FontWeight="SemiBold"/>
        <ComboBox x:Name="HttpMethodCombo" SelectedIndex="0">
          <ComboBoxItem Content="GET"/>
          <ComboBoxItem Content="POST"/>
          <ComboBoxItem Content="PUT"/>
          <ComboBoxItem Content="DELETE"/>
          <ComboBoxItem Content="PATCH"/>
        </ComboBox>
        <TextBlock Text="Headers" FontWeight="SemiBold"/>
        <DataGrid x:Name="HeadersGrid" AutoGenerateColumns="False" Height="80">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*"/>
            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*"/>
          </DataGrid.Columns>
        </DataGrid>
        <TextBlock Text="Request Body (JSON/XML)" FontWeight="SemiBold"/>
        <TextBox x:Name="RequestBodyBox" AcceptsReturn="True" Height="80" FontFamily="Consolas"/>
        <TextBlock Text="Expected Status Code" FontWeight="SemiBold"/>
        <TextBox x:Name="ExpectedStatusBox" Width="80"/>
        <TextBlock Text="Value Assertions" FontWeight="SemiBold"/>
        <DataGrid x:Name="AssertionsGrid" AutoGenerateColumns="False" Height="80">
          <DataGrid.Columns>
            <DataGridTextColumn Header="JSONPath" Binding="{Binding Path}" Width="2*"/>
            <DataGridTextColumn Header="Expected Value" Binding="{Binding ExpectedValue}" Width="2*"/>
          </DataGrid.Columns>
        </DataGrid>
      </StackPanel>
      <!-- Right: Response Display -->
      <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="4" Spacing="10">
        <TextBlock Text="Response" FontWeight="SemiBold"/>
        <TextBox x:Name="ResponseBox" AcceptsReturn="True" Height="180" FontFamily="Consolas" IsReadOnly="True" Background="#181818" Foreground="Lime"/>
        <TextBlock Text="Response Headers" FontWeight="SemiBold"/>
        <TextBox x:Name="ResponseHeadersBox" AcceptsReturn="True" Height="60" FontFamily="Consolas" IsReadOnly="True"/>
        <TextBlock Text="Test Results" FontWeight="SemiBold"/>
        <TextBox x:Name="TestResultsBox" AcceptsReturn="True" Height="60" FontFamily="Consolas" IsReadOnly="True"/>
      </StackPanel>
    </Grid>
  </DockPanel>
</UserControl>

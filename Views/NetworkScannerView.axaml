<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ProgrammersToolKit.Views.NetworkScannerView"
             x:CompileBindings="False">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="16">
      <TextBlock Text="Network Reconnaissance Scanner" FontWeight="Bold" FontSize="20"/>
      
      <!-- Target Configuration -->
      <StackPanel Spacing="8">
        <TextBlock Text="Target Configuration" FontWeight="SemiBold" FontSize="16"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Target:" VerticalAlignment="Center" Width="80"/>
          <TextBox x:Name="TargetBox" Watermark="192.168.1.1 or example.com" Width="200"/>
          <TextBlock Text="Port Range:" VerticalAlignment="Center" Margin="20,0,0,0"/>
          <TextBox x:Name="PortRangeBox" Text="1-1000" Width="100"/>
          <Button x:Name="QuickScanBtn" Content="Quick Scan" Width="100" Background="#0078D4" Foreground="White"/>
        </StackPanel>
      </StackPanel>

      <!-- Advanced Port Scanning -->
      <StackPanel Spacing="8">
        <TextBlock Text="Advanced Port Scanning" FontWeight="SemiBold" FontSize="16"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <CheckBox x:Name="TcpScanCheck" Content="TCP Scan" IsChecked="True"/>
          <CheckBox x:Name="UdpScanCheck" Content="UDP Scan"/>
          <CheckBox x:Name="SynScanCheck" Content="SYN Scan"/>
          <CheckBox x:Name="ServiceDetectionCheck" Content="Service Detection"/>
          <CheckBox x:Name="OsDetectionCheck" Content="OS Detection"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Threads:" VerticalAlignment="Center"/>
          <NumericUpDown x:Name="ThreadCountUpDown" Value="10" Minimum="1" Maximum="100" Width="80"/>
          <TextBlock Text="Timeout (ms):" VerticalAlignment="Center" Margin="20,0,0,0"/>
          <NumericUpDown x:Name="TimeoutUpDown" Value="1000" Minimum="100" Maximum="10000" Width="80"/>
          <Button x:Name="AdvancedScanBtn" Content="Advanced Scan" Width="120" Background="#FF9800" Foreground="White"/>
        </StackPanel>
      </StackPanel>

      <!-- Quick Reconnaissance Tools -->
      <StackPanel Spacing="8">
        <TextBlock Text="Quick Reconnaissance Tools" FontWeight="SemiBold" FontSize="16"/>
        <WrapPanel Orientation="Horizontal" ItemWidth="140" ItemHeight="35">
          <Button x:Name="PingBtn" Content="Ping Test" Background="#4CAF50" Foreground="White" Margin="4"/>
          <Button x:Name="TracerouteBtn" Content="Traceroute" Background="#2196F3" Foreground="White" Margin="4"/>
          <Button x:Name="WhoisBtn" Content="WHOIS Lookup" Background="#9C27B0" Foreground="White" Margin="4"/>
          <Button x:Name="DnsLookupBtn" Content="DNS Lookup" Background="#FF5722" Foreground="White" Margin="4"/>
          <Button x:Name="ReverseDnsBtn" Content="Reverse DNS" Background="#795548" Foreground="White" Margin="4"/>
          <Button x:Name="BannerGrabBtn" Content="Banner Grab" Background="#607D8B" Foreground="White" Margin="4"/>
        </WrapPanel>
      </StackPanel>

      <!-- Vulnerability Scanning -->
      <StackPanel Spacing="8">
        <TextBlock Text="Vulnerability Scanning" FontWeight="SemiBold" FontSize="16"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <ComboBox x:Name="VulnScanTypeCombo" Width="180" SelectedIndex="0">
            <ComboBoxItem Content="Common Vulnerabilities"/>
            <ComboBoxItem Content="Web Application Scan"/>
            <ComboBoxItem Content="Network Service Scan"/>
            <ComboBoxItem Content="SMB/NetBIOS Scan"/>
            <ComboBoxItem Content="SSH/FTP Brute Force"/>
            <ComboBoxItem Content="Custom Script Scan"/>
          </ComboBox>
          <Button x:Name="VulnScanBtn" Content="Start Vulnerability Scan" Width="180" Background="#F44336" Foreground="White"/>
          <Button x:Name="StopScanBtn" Content="Stop" Width="60" Background="#9E9E9E" Foreground="White"/>
        </StackPanel>
      </StackPanel>

      <!-- Results Display -->
      <StackPanel Spacing="8">
        <TextBlock Text="Scan Results" FontWeight="SemiBold" FontSize="16"/>
        <TabControl x:Name="ResultsTabView" Height="350">
          <TabItem Header="Open Ports">
            <DataGrid x:Name="PortsDataGrid" AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="80"/>
                <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80"/>
                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="80"/>
                <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="120"/>
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="150"/>
                <DataGridTextColumn Header="Banner" Binding="{Binding Banner}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Host Information">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="10">
                <TextBlock x:Name="HostInfoText" Text="No host information available" FontFamily="Consolas"/>
                <TextBlock Text="Operating System:" FontWeight="Bold" Margin="0,10,0,0"/>
                <TextBox x:Name="OsInfoBox" AcceptsReturn="True" Height="60" IsReadOnly="True" FontFamily="Consolas"/>
                <TextBlock Text="Network Details:" FontWeight="Bold" Margin="0,10,0,0"/>
                <TextBox x:Name="NetworkDetailsBox" AcceptsReturn="True" Height="80" IsReadOnly="True" FontFamily="Consolas"/>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Vulnerabilities">
            <DataGrid x:Name="VulnDataGrid" AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="80"/>
                <DataGridTextColumn Header="CVE ID" Binding="{Binding CveId}" Width="120"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="60"/>
                <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="100"/>
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Raw Output">
            <ScrollViewer>
              <TextBox x:Name="RawOutputBox" AcceptsReturn="True" IsReadOnly="True" FontFamily="Consolas" Background="#1E1E1E" Foreground="#00FF00"/>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </StackPanel>

      <!-- Export and Actions -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="ExportResultsBtn" Content="Export Results" Width="120" Background="#4CAF50" Foreground="White"/>
        <Button x:Name="SaveReportBtn" Content="Save Report" Width="120"/>
        <Button x:Name="ClearResultsBtn" Content="Clear Results" Width="120" Background="#F44336" Foreground="White"/>
        <ProgressBar x:Name="ScanProgressBar" Width="200" Height="20" IsVisible="False"/>
      </StackPanel>

      <TextBlock x:Name="StatusText" Text="Ready to scan..." Foreground="Gray" Margin="0,16,0,0"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
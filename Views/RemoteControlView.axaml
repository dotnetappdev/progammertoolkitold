<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ProgrammersToolKit.Views.RemoteControlView">
  <StackPanel Margin="32">
    <TextBlock Text="Remote Control" FontWeight="Bold" FontSize="{DynamicResource FontSizeLarge}" Foreground="{DynamicResource TextColor}"/>
    <TextBlock Text="Enable or disable remote mouse/keyboard control." Margin="0,8,0,0" Foreground="{DynamicResource TextColor}"/>
    <ToggleSwitch x:Name="RemoteControlToggle" Content="Allow Remote Control"/>
  </StackPanel>
</UserControl>

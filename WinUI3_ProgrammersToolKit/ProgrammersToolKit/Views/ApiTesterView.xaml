<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ProgrammersToolKit.Views.ApiTesterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ScrollViewer>
        <StackPanel Margin="32" Spacing="12">
            <!-- Test Management -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Test Name:" VerticalAlignment="Center"/>
                <TextBox x:Name="TestNameBox" Width="200" PlaceholderText="Optional name for this test"/>
                <Button x:Name="ExportTestsBtn" Content="Export Tests" Width="120"/>
                <Button x:Name="ImportTestsBtn" Content="Import Tests" Width="120"/>
            </StackPanel>
            
            <TextBlock Text="API Tester" FontWeight="Bold" FontSize="18"/>
            
            <!-- Request Configuration -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="MethodCombo" Width="80" SelectedIndex="0">
                    <ComboBoxItem Content="GET"/>
                    <ComboBoxItem Content="POST"/>
                    <ComboBoxItem Content="PUT"/>
                    <ComboBoxItem Content="DELETE"/>
                    <ComboBoxItem Content="PATCH"/>
                </ComboBox>
                <TextBox x:Name="UrlBox" PlaceholderText="https://api.example.com/endpoint" Width="340"/>
                <Button x:Name="SendBtn" Content="Send" Width="80"/>
                <Button x:Name="SaveCallBtn" Content="Save Call" Width="100"/>
                <Button x:Name="DeleteCallBtn" Content="Delete" Width="80"/>
            </StackPanel>
            
            <!-- Headers -->
            <Expander Header="Headers" IsExpanded="False">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <ScrollViewer Height="100" VerticalScrollBarVisibility="Auto">
                        <ListView x:Name="HeadersList" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding Key, Mode=TwoWay}" PlaceholderText="Header name" Margin="0,0,4,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay}" PlaceholderText="Header value" Margin="4,0,4,0"/>
                                        <Button Grid.Column="2" Content="✕" Width="30" Height="30" Margin="4,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                    <Button x:Name="AddHeaderBtn" Content="Add Header" Width="100" HorizontalAlignment="Left"/>
                </StackPanel>
            </Expander>
            
            <!-- JSON Body -->
            <Expander Header="JSON Body (for POST/PUT/PATCH)" IsExpanded="False">
                <TextBox x:Name="JsonBodyBox" 
                         AcceptsReturn="True" 
                         Height="120" 
                         FontFamily="Consolas"
                         PlaceholderText="Enter JSON body here..."
                         Margin="0,8,0,0"/>
            </Expander>
            
            <!-- Expected Response -->
            <Expander Header="Expected Response" IsExpanded="False">
                <StackPanel Spacing="6" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Status Code:" VerticalAlignment="Center"/>
                        <TextBox x:Name="ExpectedStatusBox" Width="60" PlaceholderText="200"/>
                    </StackPanel>
                    <TextBlock Text="Expected JSON (optional):"/>
                    <TextBox x:Name="ExpectedJsonBox" 
                             AcceptsReturn="True" 
                             Height="60" 
                             FontFamily="Consolas"
                             PlaceholderText="Expected JSON response..."/>
                    <TextBlock Text="Expected XML (optional):"/>
                    <TextBox x:Name="ExpectedXmlBox" 
                             AcceptsReturn="True" 
                             Height="60" 
                             FontFamily="Consolas"
                             PlaceholderText="Expected XML response..."/>
                </StackPanel>
            </Expander>
            
            <!-- Value Assertions -->
            <Expander Header="Value Assertions (JSONPath)" IsExpanded="False">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <ScrollViewer Height="100" VerticalScrollBarVisibility="Auto">
                        <ListView x:Name="AssertionsList" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding JsonPath, Mode=TwoWay}" PlaceholderText="$.property" Margin="0,0,4,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding ExpectedValue, Mode=TwoWay}" PlaceholderText="Expected value" Margin="4,0,4,0"/>
                                        <Button Grid.Column="2" Content="✕" Width="30" Height="30" Margin="4,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                    <Button x:Name="AddAssertionBtn" Content="Add Assertion" Width="120" HorizontalAlignment="Left"/>
                </StackPanel>
            </Expander>
            
            <!-- Response Section -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                <TextBlock Text="Response" FontWeight="SemiBold"/>
                <Button x:Name="RunAllTestsBtn" 
                        Content="Run All Tests" 
                        Width="120" 
                        Background="#0078D4" 
                        Foreground="White" 
                        FontWeight="Bold"/>
            </StackPanel>
            
            <Border Background="#1E1E1E" CornerRadius="4" Padding="8">
                <TextBox x:Name="ResponseBox" 
                         AcceptsReturn="True" 
                         Height="160" 
                         IsReadOnly="True" 
                         FontFamily="Consolas" 
                         Background="Transparent"
                         Foreground="Lime"
                         BorderThickness="0"
                         PlaceholderText="Response will appear here..."/>
            </Border>
            
            <TextBlock x:Name="TestResultBlock" FontWeight="Bold" Margin="0,8,0,0"/>
            
            <!-- Saved Calls -->
            <TextBlock Text="Saved Calls" FontWeight="SemiBold" Margin="0,12,0,0"/>
            <ListView x:Name="SavedCallsList" Height="100" BorderBrush="Gray" BorderThickness="1"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
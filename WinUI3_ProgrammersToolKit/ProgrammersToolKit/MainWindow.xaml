<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ProgrammersToolKit.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:ProgrammersToolKit.Views"
    Title="Programmers Toolkit"
    Width="1100" Height="750">
    
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>
    
    <Grid>
        <Grid.Resources>
            <!-- Theme Colors -->
            <SolidColorBrush x:Key="AccentColor" Color="#2563eb"/>
            <SolidColorBrush x:Key="BackgroundColor" Color="#ffffff"/>
            <SolidColorBrush x:Key="SidebarColor" Color="#f3f6fc"/>
            <SolidColorBrush x:Key="ButtonColor" Color="#e5eaf5"/>
            <SolidColorBrush x:Key="ButtonHoverColor" Color="#dbeafe"/>
            <SolidColorBrush x:Key="TextColor" Color="#1a1a1a"/>
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Theme Selection -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,24,0" Spacing="16">
            <RadioButton x:Name="SystemThemeRadio" Content="System" IsChecked="True" GroupName="ThemeGroup"/>
            <RadioButton x:Name="LightThemeRadio" Content="Light" GroupName="ThemeGroup"/>
            <RadioButton x:Name="DarkThemeRadio" Content="Dark" GroupName="ThemeGroup"/>
        </StackPanel>
        
        <!-- Main Content -->
        <views:MainView Grid.Row="1"/>
    </Grid>
</Window>